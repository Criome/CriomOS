[
  {
    "context": "Editor && vim_mode == 'normal'",
    "bindings": {
      "j": "vim::Undo",
      "t": ["workspace::SwitchMode", "Insert"],

      "u": "editor::MoveUp",
      "e": "editor::MoveDown",
      "n": "editor::MoveLeft",
      "i": "editor::MoveRight",
      "l": "editor::MoveToPreviousWordStart",
      "y": "editor::MoveToNextWordStart",

      "s": "editor::MoveToBeginningOfLine",
      "r": "editor::MoveToEndOfLine",
      "p": "editor::DeleteBlock",
      "c": "editor::CopyLine",
      "v": "editor::Paste",
      "a": "workspace::NewCommandPalette",
      "d": "editor::SelectNext",
      "m": "editor::GoToMatchingBracket",

      "q": "editor::CutLine",
      "f": "editor::DeletePreviousWord",
      ";": "editor::DeleteNextWord",
      "h": "editor::DeleteBackward",
      "o": "editor::ToggleComments",
      "x": "project_search::Deploy",
      "b": "editor::GoToNextBracket",
      "g": "workspace::ActivateNextPane",

      "space": ["workspace::ToggleSubMode", "Leader"]
    }
  },
  {
    "context": "Editor && vim_mode == 'normal' && sub_mode == 'Leader'",
    "bindings": {
      "space": ["workspace::SwitchMode", "Insert"],
      "a": "editor::SelectAll",
      "s": "editor::MoveToBeginningOfDocument",
      "x": "editor::MoveToEndOfDocument",
      "l": "workspace::CloseActiveItem",
      "k": "workspace::NewBufferFinder",
      "o": "recenter-top-bottom",
      "g": "project_panel::ToggleFocus",
      "r": "workspace::Save",
      "e": ["workspace::ToggleSubMode", "NavigateFS"],
      "j": ["workspace::ToggleSubMode", "MultiCursor"]
    }
  },
  {
    "context": "Editor && vim_mode == 'insert'",
    "bindings": {
      "escape": "vim::NormalBefore"
    }
  },
  {
    "context": "Editor && vim_mode == 'normal' && sub_mode == 'NavigateFS'",
    "bindings": {
      "s": "project_search::Deploy",
      "n": "workspace::NewBufferFinder",
      "e": "workspace::NewFileFinder",
      "u": "project_panel::ToggleFocus",
      "i": "git::OpenGitFiles",
      "r": "workspace::NewFileFinder"
    }
  },
  {
    "context": "Editor && vim_mode == 'normal' && sub_mode == 'MultiCursor'",
    "bindings": {
      "s": "editor::SelectAllMatches",
      "n": "editor::SelectPreviousMatch",
      "u": "editor::SelectPreviousMatch",
      "e": "editor::SelectNextMatch",
      "i": "editor::SelectNextMatch",
      "l": "editor::FindPrevious",
      "y": "editor::FindNext"
    }
  }
]
